# -----------------------------
# Frontend build-time variables
# -----------------------------

# Required: Supabase public project URL and anon key used by the React app.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY=""

# Optional: public backend base URL for split deployments.
# Leave blank in same-origin local dev with `npm run dev`.
VITE_API_URL=""


# --------------------------
# Backend runtime variables
# --------------------------

# Required: backend Supabase access and AI analysis.
SUPABASE_SERVICE_ROLE_KEY=""
OPENAI_API_KEY=""

# Required: the backend refuses to start without these two secrets.
# Generate unique values with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOOGLE_OAUTH_STATE_SECRET=""
GOOGLE_TOKEN_ENCRYPTION_KEY=""

# Optional: backend port for local/dev hosting.
PORT="3000"

# Recommended for local dev, required for split frontend/backend deployments.
APP_URL="http://localhost:3000"
API_PUBLIC_URL="http://localhost:3000"

# Optional: comma-separated extra frontend origins allowed to call the API.
FRONTEND_CORS_ORIGINS=""

# Optional: explicit Google OAuth callback override.
# If blank, the backend uses `${API_PUBLIC_URL}/api/auth/google/callback`
# or the current request origin in same-origin local dev.
GOOGLE_OAUTH_REDIRECT_URI=""

# Optional: required only if you enable Google Drive as a source.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional OpenAI model overrides.
OPENAI_ANALYSIS_MODEL="gpt-4.1-mini"
OPENAI_CHAT_MODEL="gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_DIMENSIONS="768"


# --------------------------
# Weekly digest email
# --------------------------

# Optional: required only for the weekly digest/test-send routes.
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_REPLY_TO=""
RESEND_TEST_RECIPIENT=""
WEEKLY_DIGEST_CRON_SECRET=""
