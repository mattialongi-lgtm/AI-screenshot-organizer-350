# -----------------------------
# Frontend build-time variables
# -----------------------------

# Supabase public project URL.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"

# Supabase public anon key.
VITE_SUPABASE_ANON_KEY=""

# Public backend base URL used by the frontend in split deployments.
# Local same-origin dev with `npm run dev`: leave blank.
# Vercel -> Render production: "https://your-render-service.onrender.com"
VITE_API_URL=""


# --------------------------
# Backend runtime variables
# --------------------------

# Supabase service role key used by the API server.
SUPABASE_SERVICE_ROLE_KEY=""

# Optional database connection string if you use direct SQL or migrations.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT.supabase.co:5432/postgres"

# Public frontend URL where the React app is hosted.
# Local same-origin dev: "http://localhost:3000"
# Vercel production: "https://your-app.vercel.app"
APP_URL="http://localhost:3000"

# Optional extra frontend origins allowed to call the API in split deployments.
# Comma-separate values when you have preview/staging frontends in addition to APP_URL.
FRONTEND_CORS_ORIGINS=""

# Public backend URL where `server.ts` is reachable.
# Local dev: "http://localhost:3000"
# Render production: "https://your-render-service.onrender.com"
API_PUBLIC_URL="http://localhost:3000"

# Optional explicit callback override.
# If blank, the server falls back to:
#   ${API_PUBLIC_URL}/api/auth/google/callback
# or the current request origin in same-origin local dev.
GOOGLE_OAUTH_REDIRECT_URI=""

# Google OAuth client credentials from Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Required: server refuses to start without these. Each must be a unique secret — never share values between them or with SUPABASE_SERVICE_ROLE_KEY.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOOGLE_OAUTH_STATE_SECRET=""
GOOGLE_TOKEN_ENCRYPTION_KEY=""

# Optional server-side OpenAI key for `/api/analyze`, `/api/embed`, `/api/ask`, and `/api/chat`.
OPENAI_API_KEY=""

# Optional OpenAI model overrides for backend analysis, chat, and embeddings.
OPENAI_ANALYSIS_MODEL="gpt-4.1-mini"
OPENAI_CHAT_MODEL="gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_DIMENSIONS="768"

# --------------------------
# Resend email delivery
# --------------------------

# Resend API key, e.g. re_xxxxxxxxx
RESEND_API_KEY=""

# Verified sender, e.g. ScreenSort <digest@yourdomain.com>
RESEND_FROM_EMAIL=""

# Optional reply-to address
RESEND_REPLY_TO=""

# Secret used by the weekly scheduler to trigger the batch digest job.
WEEKLY_DIGEST_CRON_SECRET=""
